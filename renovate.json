{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "customManagers:biomeVersions"],
  "enabledManagers": ["npm", "dockerfile", "docker-compose", "custom.regex"],
  "timezone": "UTC",
  "schedule": ["after 8am and before 9am on Monday"],
  "prConcurrentLimit": 5,
  "automerge": false,
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "ignoreDeps": ["@openmrs/esm-app-shell", "@openmrs/esm-offline", "workbox-window"],
  "packageRules": [
    {
      "description": "Keep Biome package and schema updates together.",
      "matchPackageNames": ["@biomejs/biome"],
      "groupName": "biome",
      "groupSlug": "biome"
    },
    {
      "description": "Group non-major Docker image updates.",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["digest", "minor", "patch", "pin", "pinDigest"],
      "groupName": "docker",
      "groupSlug": "docker"
    },
    {
      "description": "Group non-major tooling updates.",
      "matchPackageNames": [
        "/^@biomejs\\//",
        "/^eslint/",
        "/^@typescript-eslint\\//",
        "prettier",
        "/^@playwright\\//",
        "turbo",
        "typescript",
        "typescript-eslint"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "tooling",
      "groupSlug": "tooling"
    },
    {
      "description": "Ignore internal workspace protocol dependencies.",
      "matchManagers": ["npm"],
      "matchCurrentValue": "/^workspace:/",
      "enabled": false
    },
    {
      "description": "Ignore packageManager yarn field updates for now.",
      "matchManagers": ["npm"],
      "matchPackageNames": ["yarn"],
      "enabled": false
    }
  ]
}

{
  "name": "@sihsalus/esm-form-engine-lib",
  "version": "4.1.0",
  "description": "React Form Engine for O3",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "src/index.ts",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.*",
    "!src/setup-tests.ts",
    "!src/utils/test-utils.ts",
    "!src/zscore-tests",
    "README.md",
    "LICENSE.txt",
    "readme"
  ],
  "license": "MIT",
  "homepage": "https://github.com/openmrs/openmrs-esm-form-engine-lib#readme",
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "lint": "node ../../tooling/scripts/run-biome.js lint src",
    "test": "TZ=UTC jest --config ./jest.config.js --passWithNoTests --color",
    "test:watch": "TZ=UTC jest --config ./jest.config.js --watch --color",
    "typescript": "tsc",
    "build": "rimraf dist && concurrently \"swc --copy-files --ignore '**/*.test.*' --ignore '**/setup-tests.*' --ignore '**/test-utils.*' src -d dist\" \"tsc --project tsconfig.build.json\"",
    "coverage": "yarn test --coverage",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/**/*.ts' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0",
    "classnames": "^2.5.1",
    "lodash-es": "^4.17.21",
    "react-error-boundary": "^4.0.13",
    "react-hook-form": "^7.52.0",
    "react-markdown": "^9.0.1",
    "react-waypoint": "^10.3.0",
    "react-webcam": "^7.2.0"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "9.x",
    "dayjs": "1.x",
    "i18next": "25.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "9.0.2",
    "@openmrs/esm-styleguide": "workspace:*",
    "@swc/cli": "^0.1.65",
    "@swc/core": "^1.5.7",
    "@swc/jest": "^0.2.36",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.4",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.2",
    "concurrently": "^6.5.1",
    "dayjs": "^1.11.11",
    "husky": "^8.0.3",
    "i18next": "^25.0.0",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-when": "^3.6.0",
    "lint-staged": "^15.2.2",
    "openmrs": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "resize-observer-polyfill": "^1.5.1",
    "rimraf": "^5.0.0",
    "sass": "^1.77.2",
    "swr": "^2.2.5",
    "turbo": "^2.5.2",
    "typescript": "^6.0.0"
  },
  "packageManager": "yarn@4.10.3"
}

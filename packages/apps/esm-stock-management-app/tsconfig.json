{
  "extends": "../../tooling/tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "node",
    "lib": ["dom", "scripthost", "es2020", "es2021", "es2022"],
    "paths": {
      "@mocks": ["../../test-utils/mocks"],
      "@tools": ["./tools"],
      "@openmrs/*": ["../../../node_modules/@openmrs/*"],

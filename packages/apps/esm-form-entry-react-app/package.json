{
  "name": "@sihsalus/esm-form-entry-react-app",
  "version": "9.2.2",
  "license": "MPL-2.0",
  "description": "React replacement for the Angular form entry app, wrapping @sihsalus/esm-form-engine-lib",
  "browser": "dist/openmrs-esm-form-entry-react-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "npm run serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "jest --config jest.config.js --verbose false --passWithNoTests --color",
    "test:watch": "cross-env TZ=UTC jest --watch --config jest.config.js --color",
    "coverage": "yarn test --coverage",
    "typescript": "tsc --noEmit",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/**/*.modal.tsx' 'src/**/*.extension.tsx' 'src/**/*.workspace.tsx' 'src/**/*.hook.tsx' 'src/index.ts' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs"
  ],
  "dependencies": {
    "@carbon/react": "^1.47.0",
    "@sihsalus/esm-form-engine-lib": "workspace:*",
    "lodash-es": "^4.17.21",
    "react-error-boundary": "^4.0.13"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-patient-common-lib": "*",
    "dayjs": "1.x",
    "i18next": "25.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-patient-common-lib": "workspace:*",
    "@rspack/cli": "1.7.11",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "openmrs": "workspace:*",
    "typescript": "^6.0.0"
  }
}

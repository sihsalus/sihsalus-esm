{
    "$schema": "https://json.openmrs.org/routes.schema.json",
    "backendDependencies": {
        "webservices.rest": ">=2.2.0"
    },
    "pages": [
        {
            "component": "root",
            "route": "odontogram"
        }
    ],
    "extensions": [
        {
            "name": "odontogram-dashboard-link",
            "component": "odontogramDashboardLink",
            "slot": "special-clinics-slot",
            "meta": {
                "slot": "patient-chart-odontogram-slot",
                "columns": 1,
                "title": "Odontograma",
                "path": "odontogram",
                "layoutMode": "anchored"
            }
        },
        {
            "name": "odontogram-widget",
            "component": "odontogramWidget",
            "slot": "patient-chart-odontogram-slot",
            "order": 0,
            "online": true,
            "offline": false
        }
    ],
    "workspaces": [
        {
            "name": "odontogram-form-workspace",
            "component": "odontogramWorkspace",
            "type": "form",
            "title": "odontogramWorkspaceTitle",
            "canHide": true
        }
    ]
}

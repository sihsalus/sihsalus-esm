{
  "name": "@sihsalus/esm-dispensing-app",
  "version": "1.10.0",
  "license": "MPL-2.0",
  "description": "Medication dispensing application",
  "browser": "dist/openmrs-esm-dispensing-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "typescript": "tsc",
    "verify": "turbo run lint test typescript",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/**/*.workspace.tsx' 'src/**/*.modal.tsx' 'src/index.ts' --config ../../tooling/scripts/i18next-parser.config.js",
    "check-translations": "yarn extract-translations && git diff --exit-code -- translations/en.json",
    "coverage": "yarn test --coverage",
    "test-e2e": "yarn --cwd ../../.. playwright test --config e2e/dispensing/playwright.config.ts"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "microfrontends",
    "medication",
    "dispensing",
    "pharmacy"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/openmrs-esm-dispensing.git"
  },
  "homepage": "https://github.com/openmrs/openmrs-esm-dispensing#readme",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/openmrs/openmrs-esm-dispensing/issues"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0",
    "classnames": "^2.5.1",
    "lodash-es": "^4.17.21",
    "react-to-print": "^2.14.13"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "*",
    "dayjs": "1.x",
    "react": "18.x",
    "react-dom": "18.x",
    "react-i18next": "16.x",
    "rxjs": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "workspace:*",
    "@playwright/test": "^1.52.0",
    "@swc/core": "1.15.21",
    "@swc/jest": "^0.2.36",
    "@testing-library/dom": "^8.20.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^28.1.4",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.1.7",
    "@types/webpack-env": "^1.16.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.3.1",
    "i18next": "^25.0.0",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "openmrs": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.3.0",
    "rxjs": "^6.6.7",
    "swr": "^2.2.5",
    "turbo": "^2.9.1",
    "typescript": "^6.0.0"
  },
  "packageManager": "yarn@4.10.3"
}

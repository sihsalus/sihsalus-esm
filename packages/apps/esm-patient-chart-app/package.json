{
  "name": "@sihsalus/esm-patient-chart-app",
  "version": "12.1.0",
  "license": "MPL-2.0",
  "description": "Patient dashboard microfrontend for the OpenMRS SPA",
  "browser": "dist/openmrs-esm-patient-chart-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "npm run serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "TZ=UTC jest --config jest.config.js --verbose false --passWithNoTests --color",
    "test:watch": "TZ=UTC jest --watch --config jest.config.js --color",
    "coverage": "yarn test --coverage",
    "typescript": "tsc --noEmit",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/**/*.modal.tsx' 'src/**/*.extension.tsx' 'src/**/*.workspace.tsx' 'src/**/*.hook.tsx' 'src/index.ts' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "microfrontends",
    "peruHCE"
  ],
  "homepage": "https://github.com/PROYECTO-SANTACLOTILDE/openmrs-esm-patient-chart#readme",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PROYECTO-SANTACLOTILDE/openmrs-esm-patient-chart.git"
  },
  "bugs": {
    "url": "https://github.com/PROYECTO-SANTACLOTILDE/openmrs-esm-patient-chart/issues"
  },
  "dependencies": {
    "@sihsalus/esm-rbac": "workspace:*",
    "lodash-es": "^4.17.21",
    "uuid": "^8.3.2"
  },
  "peerDependencies": {
    "@carbon/react": "1.x",
    "@openmrs/esm-framework": "9.x",
    "@openmrs/esm-patient-common-lib": "*",
    "@openmrs/esm-styleguide": "*",
    "dayjs": "1.x",
    "lodash-es": "4.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x",
    "single-spa": "6.x",
    "single-spa-react": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-styleguide": "*",
    "@rspack/cli": "1.7.11",
    "@types/uuid": "^9.0.4",
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "openmrs": "workspace:*",
    "typescript": "^5.8.3"
  }
}

{
  "name": "@sihsalus/esm-coststructure-app",
  "version": "1.0.0-alpha",
  "license": "MPL-2.0",
  "description": "OpenMRS ESM Cost Structure Microfrontend Module for SIHSALUS",
  "browser": "dist/sihsalus-esm-coststructure-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "prettier": "node ../../tooling/scripts/run-biome.js format --write src",
    "typescript": "tsc --noEmit",
    "test": "jest --config jest.config.js --passWithNoTests",
    "verify": "turbo lint typescript coverage",
    "coverage": "yarn test --coverage",
    "extract-translations": "i18next \"src/**/*.component.tsx\" --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "files": [
    "dist",
    "src",
    "translations"
  ],
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "sihsalus"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sihsalus/sihsalus-esm-modules.git"
  },
  "homepage": "https://github.com/sihsalus/sihsalus-esm-modules#readme",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/sihsalus/sihsalus-esm-modules/issues"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sihsalus/esm-rbac": "workspace:*",
    "lodash-es": "^4.17.21",
    "react-hook-form": "^7.66.0",
    "swr": "^2.3.6",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "@carbon/react": "1.x",
    "@openmrs/esm-framework": "*",
    "dayjs": "1.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-styleguide": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@rspack/cli": "1.7.11",
    "@swc/cli": "^0.3.12",
    "@swc/core": "1.15.21",
    "@swc/jest": "^0.2.36",
    "@testing-library/dom": "^10.1.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@types/webpack-env": "^1.18.1",
    "dayjs": "^1.11.13",
    "dotenv": "^17.3.1",
    "i18next": "^25.0.0",
    "i18next-parser": "^9.0.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "openmrs": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.14.1",
    "rxjs": "^6.6.7",
    "turbo": "^2.9.1",
    "typescript": "^6.0.0"
  }
}

{
  "name": "@sihsalus/esm-sihsalus-consulta-externa-app",
  "version": "1.8.0",
  "description": "Módulo de Consulta Externa para el contexto de salud peruano - OpenMRS O3",
  "browser": "dist/sihsalus-esm-sihsalus-consulta-externa-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "npm run serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "eslint src --ext ts,tsx",
    "test": "cross-env TZ=UTC jest --config jest.config.js --verbose false --passWithNoTests --color",
    "test:watch": "cross-env TZ=UTC jest --watch --config jest.config.js --color",
    "coverage": "yarn test --coverage",
    "typescript": "tsc",
    "extract-translations": "i18next \"src/**/*.component.tsx\" \"src/**/*.extension.tsx\" \"src/**/*modal.tsx\" \"src/**/*.workspace.tsx\" \"src/index.ts\" --config ../../tools/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "sihsalus"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/sihsalus/sihsalus-esm-modules#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sihsalus/sihsalus-esm-modules.git"
  },
  "bugs": {
    "url": "https://github.com/sihsalus/sihsalus-esm-modules/issues"
  },
  "dependencies": {
    "@carbon/charts": "^1.23.7",
    "@carbon/charts-react": "^1.23.7",
    "@hookform/resolvers": "^3.3.1",
    "classnames": "^2.5.1",
    "lodash-es": "^4.17.21",
    "react-hook-form": "^7.56.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@carbon/colors": "1.x",
    "@carbon/layout": "1.x",
    "@carbon/react": "1.x",
    "@carbon/styles": "1.x",
    "@openmrs/esm-framework": "9.0.2",
    "@openmrs/esm-patient-common-lib": ">=9.0.0",
    "dayjs": "1.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-is": "19.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x",
    "single-spa": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-patient-common-lib": ">=9.0.0",
    "@rspack/cli": "1.3.15",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0"
  }
}

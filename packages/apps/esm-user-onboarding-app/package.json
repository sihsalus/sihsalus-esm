{
  "name": "@sihsalus/esm-user-onboarding-app",
  "version": "1.0.0-alpha",
  "license": "MPL-2.0",
  "description": "An OpenMRS microfrontend for user onboarding walkthroughs",
  "browser": "dist/openmrs-esm-user-onboarding-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "prettier": "node ../../tooling/scripts/run-biome.js format --write src",
    "typescript": "tsc",
    "test": "vitest run --passWithNoTests",
    "verify": "turbo lint typescript coverage",
    "coverage": "vitest run --coverage --passWithNoTests",
    "extract-translations": "i18next 'src/**/*.component.tsx' --config ../../tooling/scripts/i18next-parser.config.js",
    "test-e2e": "yarn --cwd ../../.. playwright test --config e2e/user-onboarding/playwright.config.ts"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "microfrontends"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/openmrs-esm-user-onboarding.git"
  },
  "homepage": "https://github.com/openmrs/openmrs-esm-user-onboarding#readme",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/openmrs/openmrs-esm-user-onboarding/issues"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0",
    "@sihsalus/esm-rbac": "workspace:*",
    "lodash-es": "^4.17.21",
    "react-joyride": "^2.8.2"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "*",
    "dayjs": "1.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-styleguide": "workspace:*",
    "@playwright/test": "^1.52.0",
    "@swc/cli": "^0.3.12",
    "@swc/core": "1.15.21",
    "@swc/jest": "^0.2.36",
    "@testing-library/dom": "^10.1.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.6",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@types/webpack-env": "^1.18.1",
    "css-loader": "^6.8.1",
    "dayjs": "1.x",
    "dotenv": "^16.0.3",
    "i18next": "^25.0.0",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "openmrs": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.14.1",
    "rxjs": "^6.6.7",
    "swc-loader": "^0.2.3",
    "turbo": "^2.9.1",
    "typescript": "^6.0.0",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  },
  "packageManager": "yarn@4.10.3"
}

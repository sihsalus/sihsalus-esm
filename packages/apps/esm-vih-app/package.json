{
  "name": "@sihsalus/esm-vih-app",
  "version": "1.0.0",
  "description": "Módulo VIH - Tamizaje, Gestión de Casos y Seguimiento de Pacientes VIH - OpenMRS O3",
  "browser": "dist/sihsalus-esm-vih-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "npm run serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "jest --config jest.config.js --verbose false --passWithNoTests --color",
    "test:watch": "cross-env TZ=UTC jest --watch --config jest.config.js --color",
    "coverage": "yarn test --coverage",
    "typescript": "tsc",
    "extract-translations": "i18next \"src/**/*.component.tsx\" \"src/**/*.extension.tsx\" \"src/**/*modal.tsx\" \"src/**/*.workspace.tsx\" \"src/index.ts\" --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "sihsalus",
    "vih",
    "hiv"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/sihsalus/sihsalus-esm-modules#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sihsalus/sihsalus-esm-modules.git"
  },
  "bugs": {
    "url": "https://github.com/sihsalus/sihsalus-esm-modules/issues"
  },
  "dependencies": {
    "@sihsalus/esm-sihsalus-shared": "workspace:*",
    "lodash-es": "^4.17.21"
  },
  "peerDependencies": {
    "@carbon/react": "1.x",
    "@carbon/styles": "1.x",
    "@openmrs/esm-framework": "9.0.2",
    "@openmrs/esm-patient-common-lib": "*",
    "dayjs": "1.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x",
    "single-spa": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-patient-common-lib": "workspace:*",
    "@rspack/cli": "1.7.11",
    "jest": "^29.7.0",
    "openmrs": "workspace:*",
    "typescript": "^5.8.3"
  }
}

{
  "name": "@sihsalus/esm-laboratory-app",
  "version": "1.3.1",
  "license": "MPL-2.0",
  "description": "An O3 frontend module for managing laboratory requests and queues",
  "browser": "dist/openmrs-esm-laboratory-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "build": "rspack --mode=production --mode production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "eslint src --ext ts,tsx",
    "prettier": "prettier --write \"src/**/*.{css,scss,ts,tsx}\" --list-different",
    "typescript": "tsc",
    "test": "jest --config jest.config.js --passWithNoTests --color",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/index.ts' --config ../../tools/i18next-parser.config.js",
    "coverage": "yarn test -- --coverage",
    "test-e2e": "playwright test"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "microfrontends",
    "laboratory"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/openmrs-esm-laboratory.git"
  },
  "homepage": "https://github.com/openmrs/openmrs-esm-laboratory#readme",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/openmrs/openmrs-esm-laboratory/issues"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0",
    "lodash-es": "^4.17.21",
    "react-hook-form": "^7.52.1"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "9.x",
    "dayjs": "1.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "next",
    "@playwright/test": "^1.52.0",
    "@swc/cli": "^0.1.62",
    "@swc/core": "^1.3.62",
    "@swc/jest": "^0.2.26",
    "@testing-library/dom": "^8.20.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^28.1.8",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "dayjs": "^1.11.11",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "file-saver": "^2.0.5",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^28.1.3",
    "jest-cli": "^28.1.3",
    "jest-environment-jsdom": "^28.1.3",
    "openmrs": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.11.2",
    "typescript": "^5.0.0"
  }
}

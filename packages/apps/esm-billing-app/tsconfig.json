{
  "extends": "../../tooling/tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "node",
    "lib": ["dom", "dom.iterable", "esnext"],
    "paths": {
      "mocks/*": ["./test-utils/mocks/*"],
      "test-utils": ["../../test-utils/index.tsx"],
      "test-utils/*": ["../../test-utils/*"],
      "tools/*": ["./tools/*"],    
      "mocks/*": [
        "./__mocks__/*"
      ],
      "tools/*": [
        "./tools/*"
      ],
      "test-utils": [
        "../../test-utils/index"
      ],
      "@openmrs/*": [
        "../../apps/*"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "esnext"
  },
  "include": ["src/**/*", "e2e/**/*", "test-utils/**/*", "../../tools/setup-tests.ts"]
}

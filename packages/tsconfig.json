{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react",
    "lib": [
      "dom",
      "es5",
      "scripthost",
      "es2015",
      "es2015.promise",
      "es2016.array.include",
      "es2018",
      "es2020",
      "es2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@openmrs/*": ["../node_modules/@openmrs/*"],
      "test-utils": ["./test-utils/index.tsx"],
      "test-utils/*": ["./test-utils/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "esnext",
    "typeRoots": ["../node_modules/@types"]
  },
  "files": ["declarations.d.ts"],
  "include": ["test-utils/**/*.ts", "test-utils/**/*.tsx", "test-utils/**/*.js"]
}

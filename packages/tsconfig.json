{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "es5",
      "scripthost",
      "es2015",
      "es2015.promise",
      "es2016.array.include",
      "es2018",
      "es2020",
      "es2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "test-utils": ["./test-utils/index.tsx"],
      "test-utils/*": ["./test-utils/*"],
      "@openmrs/*": ["./apps/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "esnext",
    "typeRoots": ["../node_modules/@types"]
  },
  "files": ["declarations.d.ts"],
  "include": [
    "__mocks__/**/*.ts",
    "__mocks__/**/*.tsx",
    "test-utils/**/*.ts",
    "test-utils/**/*.tsx",
    "test-utils/**/*.js"
  ]
}

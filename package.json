{
  "name": "@sihsalus/frontend-web",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/tooling/*",
    "packages/apps/*",
    "packages/libs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:apps": "turbo run build --filter='./packages/apps/*'",
    "assemble": "node scripts/assemble-importmap.js",
    "dev": "turbo run dev",
    "start": "node scripts/start-dev.js",
    "serve": "turbo run build --filter=openmrs --filter='@sihsalus/*' --concurrency=4 && openmrs start",
    "serve:prod": "turbo run build && node scripts/assemble-importmap.js && openmrs start",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typescript",
    "verify": "turbo run lint typescript test",
    "clean": "turbo run clean && rm -rf dist/spa",
    "setup": "yarn install && turbo run build",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.55.1",
    "@swc/core": "1.15.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/fhir": "0.0.31",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "@types/webpack-env": "^1.16.4",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.0.3",
    "eslint": "^8.55.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-playwright": "^2.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-testing-library": "^7.1.1",
    "fake-indexeddb": "^4.0.2",
    "fork-ts-checker-webpack-plugin": "^7.2.13",
    "husky": "^8.0.3",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "^3.0.0",
    "lint-staged": "^15.2.9",
    "openmrs": "workspace:*",
    "prettier": "^3.1.0",
    "swc-loader": "0.2.7",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix --max-warnings 0",
    "*.{css,scss,ts,tsx}": "prettier --write --list-different"
  },
  "packageManager": "yarn@4.13.0",
  "resolutions": {
    "sass": "1.77.8",
    "zustand": "^4.5.5",
    "webpack": "5.99.9",
    "html-webpack-plugin": "^5.5.0",
    "swr": "2.2.5",
    "@carbon/styles": "^1.102.0",
    "workbox-window@npm:^6.1.5": "patch:workbox-window@npm%3A6.6.0#~/.yarn/patches/workbox-window-npm-6.6.0-e9667fec2c.patch",
    "workbox-window@npm:6.6.0": "patch:workbox-window@npm%3A6.6.0#~/.yarn/patches/workbox-window-npm-6.6.0-e9667fec2c.patch"
  }
}

{
  "name": "@sihsalus/sihsalus-esm",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "Pontificia Universidad Catolica del Peru (PUCP) - Grupo de Investigacion y Desarrollo de Ingenieria de Software (GIDIS)",
    "email": "gonzalo.galvezc@pucp.edu.pe"
  },
  "license": "MPL-2.0",
  "workspaces": [
    "packages/tooling/*",
    "packages/apps/*",
    "packages/libs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:apps": "turbo run build --filter='./packages/apps/*'",
    "generate-config": "node packages/tooling/scripts/generate-assemble-config.js",
    "assemble": "node packages/tooling/scripts/generate-assemble-config.js && node packages/tooling/scripts/assemble-importmap.js",
    "dev": "turbo run dev",
    "start": "node packages/tooling/scripts/start-dev.js",
    "serve": "turbo run build --filter=openmrs --filter='./packages/apps/*' && openmrs start",
    "serve:prod": "turbo run build && node packages/tooling/scripts/assemble-importmap.js && openmrs start",
    "test": "cross-env TZ=UTC turbo run test --concurrency=1",
    "test:coverage": "turbo run test -- --coverage",
    "test:watch": "turbo run test:watch",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test -g \"@accessibility\"",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "turbo run lint",
    "typecheck": "turbo run typescript",
    "verify": "cross-env TZ=UTC turbo run lint typescript test",
    "verify:changed": "node packages/tooling/scripts/verify-changed.js",
    "extract-translations": "turbo run extract-translations",
    "clean": "node packages/tooling/scripts/clean-monorepo.js",
    "clean:dry-run": "node packages/tooling/scripts/clean-monorepo.js --dry-run",
    "setup": "yarn install && turbo run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@swc/core": "1.15.21",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fhir": "0.0.31",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.0.18",
    "chalk": "^4.1.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-playwright": "^2.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.1.1",
    "express": "^4.22.0",
    "fake-indexeddb": "^4.0.2",
    "http-proxy-middleware": "^2.0.9",
    "husky": "^9.1.7",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "^3.0.0",
    "lint-staged": "^16.0.0",
    "openmrs": "workspace:*",
    "prettier": "^3.8.1",
    "swc-loader": "0.2.7",
    "turbo": "^2.9.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.{css,js,json,ts,tsx}": "biome check --write",
    "*.scss": "prettier --write"
  },
  "packageManager": "yarn@4.13.0",
  "resolutions": {
    "@rspack/core": "1.7.11",
    "@rspack/cli": "1.7.11",
    "sass": "1.98.0",
    "zustand": "^4.5.5",
    "html-webpack-plugin": "^5.5.0",
    "swr": "2.4.1",
    "cross-env": "^10.1.0",
    "@carbon/styles": "^1.102.0",
    "@openmrs/esm-app-shell@npm:9.0.2": "patch:@openmrs/esm-app-shell@npm%3A9.0.2#./.yarn/patches/openmrs-esm-app-shell-npm-9.0.2-form-stack-sharing.patch",
    "@openmrs/esm-offline@npm:9.0.2": "patch:@openmrs/esm-offline@npm%3A9.0.2#./.yarn/patches/openmrs-esm-offline-npm-9.0.2-dynamic-offline-query.patch",
    "workbox-window@npm:^6.1.5": "patch:workbox-window@npm%3A6.6.0#~/.yarn/patches/workbox-window-npm-6.6.0-e9667fec2c.patch",
    "workbox-window@npm:6.6.0": "patch:workbox-window@npm%3A6.6.0#~/.yarn/patches/workbox-window-npm-6.6.0-e9667fec2c.patch",
    "@openmrs/esm-styleguide": "workspace:*"
  }
}

{
  "name": "@sihsalus/sihsalus-esm",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "Pontificia Universidad Catolica del Peru (PUCP) - Grupo de Investigacion y Desarrollo de Ingenieria de Software (GIDIS)",
    "email": "gonzalo.galvezc@pucp.edu.pe"
  },
  "license": "MPL-2.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "packages/tooling/*",
    "packages/apps/*",
    "packages/libs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:apps": "turbo run build --filter='./packages/apps/*'",
    "generate-config": "node packages/tooling/scripts/generate-assemble-config.js",
    "assemble": "node packages/tooling/scripts/generate-assemble-config.js && node packages/tooling/scripts/assemble-importmap.js",
    "validate:spa": "node packages/tooling/scripts/validate-spa-artifact.js",
    "package:spa": "yarn build:apps && yarn assemble && yarn validate:spa",
    "dev": "turbo run dev",
    "start": "node packages/tooling/scripts/start-dev.js",
    "start:dev": "cross-env SIHSALUS_BACKEND_URL=http://gidis-hsc-dev.inf.pucp.edu.pe SIHSALUS_FHIR_BASE=http://gidis-hsc-dev.inf.pucp.edu.pe/openmrs/ws/fhir2/R4 node packages/tooling/scripts/start-dev.js",
    "start:qlty": "cross-env SIHSALUS_BACKEND_URL=http://gidis-hsc-qlty.inf.pucp.edu.pe SIHSALUS_FHIR_BASE=http://gidis-hsc-qlty.inf.pucp.edu.pe/openmrs/ws/fhir2/R4 node packages/tooling/scripts/start-dev.js",
    "serve": "turbo run build --filter=openmrs --filter='./packages/apps/*' && openmrs start",
    "serve:prod": "turbo run build && node packages/tooling/scripts/assemble-importmap.js && openmrs start",
    "test": "cross-env TZ=UTC turbo run test --concurrency=1",
    "test:coverage": "turbo run test -- --coverage",
    "test:watch": "turbo run test:watch",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test -g \"@accessibility\"",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "turbo run lint",
    "typecheck": "turbo run typescript",
    "audit:workspaces": "node packages/tooling/scripts/audit-workspaces.js",
    "audit:workspaces:report": "node packages/tooling/scripts/audit-workspaces.js --report-only",
    "verify": "cross-env TZ=UTC turbo run lint typescript test",
    "verify:changed": "node packages/tooling/scripts/verify-changed.js",
    "verify:openmrs-core": "cross-env TZ=UTC node packages/tooling/scripts/verify-openmrs-core.js",
    "extract-translations": "turbo run extract-translations",
    "clean": "node packages/tooling/scripts/clean-monorepo.js",
    "clean:dry-run": "node packages/tooling/scripts/clean-monorepo.js --dry-run",
    "setup": "yarn install && turbo run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "^1.58.2",
    "@swc/core": "1.15.21",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fhir": "0.0.31",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "chalk": "^4.1.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.22.0",
    "fake-indexeddb": "^4.0.2",
    "happy-dom": "^20.9.0",
    "http-proxy-middleware": "^2.0.9",
    "husky": "^9.1.7",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "^3.0.0",
    "lint-staged": "^16.0.0",
    "openmrs": "workspace:*",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swc-loader": "0.2.7",
    "turbo": "^2.9.1",
    "typescript": "^6.0.0",
    "vitest": "4.1.0",
    "webpack": "^5.99.9"
  },
  "lint-staged": {
    "*.{css,js,json,ts,tsx}": "biome check --write",
    "*.scss": "prettier --write"
  },
  "packageManager": "yarn@4.13.0",
  "resolutions": {
    "@rspack/core": "1.7.11",
    "@rspack/cli": "1.7.11",
    "sass": "1.98.0",
    "zustand": "^4.5.5",
    "html-webpack-plugin": "^5.5.0",
    "swr": "2.4.1",
    "cross-env": "^10.1.0",
    "@carbon/styles": "^1.102.0",
    "axios": "^1.15.2",
    "fast-uri": "^3.1.2",
    "form-data": "^4.0.5",
    "picomatch": "^4.0.4",
    "serialize-javascript": "^7.0.5",
    "vite": "^8.0.13",
    "@openmrs/esm-app-shell@npm:9.0.2": "patch:@openmrs/esm-app-shell@npm%3A9.0.2#./.yarn/patches/openmrs-esm-app-shell-npm-9.0.2-form-stack-sharing.patch",
    "@openmrs/esm-offline": "workspace:*",
    "@openmrs/esm-styleguide": "workspace:*",
    "@openmrs/esm-api": "workspace:*",
    "@openmrs/esm-config": "workspace:*",
    "@openmrs/esm-dynamic-loading": "workspace:*",
    "@openmrs/esm-emr-api": "workspace:*",
    "@openmrs/esm-error-handling": "workspace:*",
    "@openmrs/esm-expression-evaluator": "workspace:*",
    "@openmrs/esm-extensions": "workspace:*",
    "@openmrs/esm-feature-flags": "workspace:*",
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-globals": "workspace:*",
    "@openmrs/esm-navigation": "workspace:*",
    "@openmrs/esm-react-utils": "workspace:*",
    "@openmrs/esm-routes": "workspace:*",
    "@openmrs/esm-state": "workspace:*",
    "@openmrs/esm-translations": "workspace:*",
    "@openmrs/esm-utils": "workspace:*"
  }
}

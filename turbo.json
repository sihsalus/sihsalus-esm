{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "concurrency": "50%",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "!src/**/*.test.*",
        "!src/**/setup-tests.*",
        "tsconfig.json",
        "tsconfig.build.json",
        "rspack.config.js",
        "rspack.config.cjs",
        "rspack.config.ts",
        ".swcrc",
        "postcss.config.js",
        "translations/**",
        "dependencies.json"
      ],
      "outputs": [
        "dist/**"
      ],
      "env": [
        "NODE_ENV",
        "NODE_OPTIONS",
        "SIHSALUS_AUTH_MODE",
        "SIHSALUS_FHIR_BASE"
      ]
    },
    "build:development": {
      "dependsOn": [
        "^build:development"
      ],
      "inputs": [
        "src/**",
        "!src/**/*.test.*",
        "tsconfig.json",
        "rspack.config.js",
        "translations/**"
      ],
      "outputs": [
        "dist/**"
      ],
      "env": [
        "NODE_ENV",
        "SIHSALUS_AUTH_MODE",
        "SIHSALUS_FHIR_BASE"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "inputs": [
        "src/**",
        "__mocks__/**",
        "mock.ts",
        "mock-jest.ts",
        "mock-jest.tsx",
        "vitest.config.ts",
        "setup-tests.ts"
      ],
      "env": ["TZ"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "coverage": {
      "inputs": [
        "src/**",
        "__mocks__/**",
        "vitest.config.ts",
        "setup-tests.ts"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "lint": {
      "inputs": [
        "src/**/*.{ts,tsx}",
        "$TURBO_ROOT$/eslint.config.js"
      ]
    },
    "typescript": {
      "dependsOn": [
        "^typescript"
      ],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "tsconfig.build.json"
      ]
    },
    "extract-translations": {
      "inputs": [
        "src/**/*.component.tsx",
        "src/**/*.extension.tsx",
        "src/**/*.modal.tsx",
        "src/**/*.resource.ts"
      ]
    },
    "e2e": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "e2e/results/**"
      ],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}